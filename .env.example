# Copy this file to .env and fill in real values. .env is gitignored; this example file is committed.

# Required for the extraction layer (Phase 0 ASML extraction and beyond)
ANTHROPIC_API_KEY=your-key-here

# Optional: override the extraction model (default: claude-haiku-4-5)
# EXTRACTION_MODEL=claude-sonnet-5

# Free, instant signup — enables US export data in collectors/mirror_trade.py
# https://api.census.gov/data/key_signup.html
# CENSUS_API_KEY=

# Free registration — will enable Japan export data (not yet implemented)
# https://www.e-stat.go.jp/en/api/
# ESTAT_APP_ID=
